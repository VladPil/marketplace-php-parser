{
    "name": "ozon/spics-test-task",
    "description": "Ozon marketplace parser with admin panel",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-redis": "*",
        "ext-swoole": "*",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "guzzlehttp/guzzle": "^7.9",
        "leocarmo/circuit-breaker-php": "^6.0",
        "symfony/asset": "^7.2",
        "symfony/config": "^7.2",
        "symfony/console": "^7.2",
        "symfony/dependency-injection": "^7.2",
        "symfony/form": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/lock": "^7.2",
        "symfony/monolog-bundle": "^4.0",
        "symfony/rate-limiter": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/validator": "^7.2",
        "symfony/var-exporter": "^7.2",
        "symfony/yaml": "^7.2",
        "twig/twig": "^3.14"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "swoole/ide-helper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
