{% extends 'base.html.twig' %}

{% block title %}Здоровье сервисов{% endblock %}

{% block styles %}
.health-desc { color: #6b7280; font-size: 13px; margin-top: 4px; line-height: 1.5; }
.health-section { margin-bottom: 24px; }
.health-section h2 { font-size: 18px; margin-bottom: 4px; }
.health-section .section-desc { color: #6b7280; font-size: 14px; margin-bottom: 16px; line-height: 1.5; }
{% endblock %}

{% block content %}
    <h1>Здоровье сервисов</h1>
    <p style="color: #6b7280; margin-bottom: 24px; line-height: 1.5;">
        На этой странице отображается текущий статус всех внешних сервисов, от которых зависит работа парсера.
        Если какой-то компонент отмечен красным — парсинг может работать некорректно или не работать вовсе.
    </p>

    <div class="card health-section">
        <h2>Solver Service</h2>
        <p class="section-desc">
            Solver — это отдельный сервис, который управляет браузером для обхода защиты маркетплейсов (капчи, антибот-системы).
            Без него парсер не сможет получать данные с защищённых страниц.
        </p>

        <table>
            <tbody>
                <tr>
                    <th style="width: 200px;">Доступность</th>
                    <td>
                        {% if solver.available %}
                            <span class="indicator indicator-green"></span>
                            <span class="status-ok">Доступен</span>
                            <div class="health-desc">Сервис отвечает на запросы и готов к работе.</div>
                        {% else %}
                            <span class="indicator indicator-red"></span>
                            <span class="status-fail">Недоступен</span>
                            <div class="health-desc">Сервис не отвечает. Проверьте, запущен ли контейнер solver-service и доступен ли он по сети.</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Статус</th>
                    <td>
                        {% if solver.status == 'ok' or solver.status == 'healthy' %}
                            <span class="status-ok">{{ solver.status }}</span>
                            <div class="health-desc">Сервис работает в штатном режиме, все внутренние проверки пройдены.</div>
                        {% else %}
                            <span class="status-fail">{{ solver.status }}</span>
                            <div class="health-desc">Сервис сообщает о проблемах. Возможно, требуется перезапуск или есть ошибки в конфигурации.</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Браузер</th>
                    <td>
                        {% if solver.browser is null %}
                            <span style="color: #999;">Нет данных</span>
                            <div class="health-desc">Не удалось получить информацию о состоянии браузера. Возможно, solver-сервис не поддерживает эту проверку.</div>
                        {% elseif solver.browser %}
                            <span class="indicator indicator-green"></span>
                            <span class="status-ok">Запущен</span>
                            <div class="health-desc">Headless-браузер (Chromium) запущен и готов выполнять запросы. Он используется для рендера страниц маркетплейсов и прохождения антибот-защиты.</div>
                        {% else %}
                            <span class="indicator indicator-red"></span>
                            <span class="status-fail">Не запущен</span>
                            <div class="health-desc">Браузер не запущен — парсинг защищённых страниц невозможен. Проверьте логи solver-service на наличие ошибок запуска Chromium.</div>
                        {% endif %}
                    </td>
                </tr>
                {% if solver.error %}
                    <tr>
                        <th>Ошибка</th>
                        <td>
                            <span class="status-fail">{{ solver.error }}</span>
                            <div class="health-desc">Текст ошибки от сервиса. Используйте его для диагностики: проверьте логи контейнера или сетевую доступность.</div>
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>

    <div class="card health-section">
        <h2>⚡ Identity Pool</h2>
        <p class="section-desc">
            Пул identity (прокси + cookies + UA) для парсинга. Каждая identity прогревается через solver-service
            и получает полный набор cookies. Парсинг возможен только при наличии готовых identity.
        </p>

        <table>
            <tbody>
                <tr>
                    <th style="width: 200px;">Готовы (ready)</th>
                    <td>
                        {% if identity_pool.ready > 0 %}
                            <span class="indicator indicator-green"></span>
                            <span class="status-ok">{{ identity_pool.ready }}</span>
                        {% else %}
                            <span class="indicator indicator-red"></span>
                            <span class="status-fail">0</span>
                            <div class="health-desc">Нет готовых identity. Парсинг невозможен. Дождитесь прогрева.</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Активны (active)</th>
                    <td>{{ identity_pool.active }}</td>
                </tr>
                <tr>
                    <th>Карантин</th>
                    <td>
                        {% if identity_pool.quarantine > 0 %}
                            <span style="color: #f59e0b; font-weight: 600;">{{ identity_pool.quarantine }}</span>
                        {% else %}
                            {{ identity_pool.quarantine }}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Всего</th>
                    <td><strong>{{ identity_pool.total }}</strong></td>
                </tr>
            </tbody>
        </table>

        {% if identity_pool.identities is not empty %}
            <h3 style="margin-top: 16px; font-size: 15px;">Детализация</h3>
            <table style="margin-top: 8px;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Прокси</th>
                        <th>Тип</th>
                        <th>Статус</th>
                        <th>Cookies</th>
                        <th>Создана</th>
                    </tr>
                </thead>
                <tbody>
                    {% for id in identity_pool.identities %}
                        <tr>
                            <td><code>{{ id.short_id }}</code></td>
                            <td>{{ id.proxy }}</td>
                            <td><span class="badge badge-info">{{ id.proxy_type }}</span></td>
                            <td>
                                {% if id.status == 'ready' %}
                                    <span class="badge badge-success">ready</span>
                                {% elseif id.status == 'active' %}
                                    <span class="badge badge-info">active</span>
                                {% elseif id.status == 'quarantine' %}
                                    <span class="badge badge-warning">quarantine</span>
                                {% else %}
                                    <span class="badge badge-debug">{{ id.status }}</span>
                                {% endif %}
                            </td>
                            <td>{{ id.cookies }}</td>
                            <td>{{ id.created_at }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
