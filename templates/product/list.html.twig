{% extends 'base.html.twig' %}

{% block title %}Товары — Админ-панель{% endblock %}

{% block content %}
<h1>Товары</h1>

{% if products is empty %}
    <div class="card">
        <p style="color: #999;">Товаров пока нет. <a href="{{ path('task_create') }}">Запустите парсинг</a></p>
    </div>
{% else %}
    <table>
        <thead>
            <tr>
                <th data-sortable>ID</th>
                <th data-sortable>External ID</th>
                <th data-sortable>Название</th>
                <th data-sortable>Категория</th>
                <th data-sortable>Цена</th>
                <th data-sortable>Рейтинг</th>
                <th data-sortable>Отзывы</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.externalId }}</td>
                <td><a href="{{ path('product_show', {id: product.id}) }}">{{ product.title|slice(0, 60) }}{% if product.title|length > 60 %}...{% endif %}</a></td>
                <td>{{ product.category ? product.category.name : '—' }}</td>
                <td data-sort-value="{{ product.price ?? 0 }}">{{ product.price ? product.price ~ ' ₽' : '—' }}</td>
                <td data-sort-value="{{ product.rating ?? 0 }}">{{ product.rating ?? '—' }}</td>
                <td data-sort-value="{{ product.reviewCount ?? 0 }}">{{ product.reviewCount ?? 0 }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
{% endblock %}
