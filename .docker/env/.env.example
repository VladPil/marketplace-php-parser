# =============================================================================
# Парсер маркетплейсов — Конфигурация
# =============================================================================
# Копируется в корень проекта как .env при `make init`
# =============================================================================

# =============================================================================
# DOCKER COMPOSE — Порты для маппинга контейнеров
# =============================================================================
MP__DOCKER__ADMIN_PORT=8202
MP__DOCKER__PARSER_HEALTH_PORT=8203
MP__DOCKER__SOLVER_PORT=8204
MP__DOCKER__DB_PORT=5433
MP__DOCKER__REDIS_PORT=6380

# =============================================================================
# DOCKER IMAGES — Настройки для контейнеров инфраструктуры
# =============================================================================

# --- PostgreSQL ---
MP__POSTGRES__POSTGRES_USER=mp
MP__POSTGRES__POSTGRES_PASSWORD=mp_secret
MP__POSTGRES__POSTGRES_DB=mp_parser

# =============================================================================
# APPLICATION — Настройки приложения
# =============================================================================
MP__APP__ENV=dev
MP__APP__SECRET=change-me-to-random-secret

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
MP__DB__HOST=postgres
MP__DB__PORT=5432
MP__DB__NAME=mp_parser
MP__DB__USER=mp
MP__DB__PASSWORD=mp_secret
MP__DB__POOL_SIZE=10

# =============================================================================
# REDIS — Очереди и дедупликация
# =============================================================================
MP__REDIS__HOST=redis
MP__REDIS__PORT=6379
MP__REDIS__DB=0
MP__REDIS__POOL_SIZE=5
MP__REDIS__PREFIX=mp:parse:

# =============================================================================
# PARSER — Настройки движка парсинга
# =============================================================================
MP__PARSER__RATE_LIMIT=5
MP__PARSER__WORKERS=4
MP__PARSER__HEALTH_PORT=9501
MP__PARSER__MAX_REVIEW_PAGES=10
MP__PARSER__MAX_RETRIES=3

# =============================================================================
# RETRY — Политика повторных попыток
# =============================================================================
MP__RETRY__BASE_DELAY=1.0
MP__RETRY__MAX_DELAY=30.0
MP__RETRY__JITTER_FACTOR=0.25

# =============================================================================
# HTTP — Настройки API клиента
# =============================================================================
MP__HTTP__API_HOST=www.ozon.ru
MP__HTTP__API_PORT=443
MP__HTTP__SSL=true
MP__HTTP__CONNECT_TIMEOUT=30
MP__HTTP__REQUEST_TIMEOUT=60

# =============================================================================
# PROXY — Прокси-серверы для парсера
# =============================================================================
MP__PROXY__ENABLED=false
MP__PROXY__LIST=

# =============================================================================
# SOLVER — Подключение к внешнему solver-service (обход анти-бот защиты)
# =============================================================================
MP__SOLVER__HOST=host.docker.internal
MP__SOLVER__PORT=8204
MP__SOLVER__REQUEST_TIMEOUT=60
MP__SOLVER__CONNECT_TIMEOUT=10
MP__SOLVER__SESSION_TTL=1500
MP__SOLVER__MAX_RETRIES=2
